# ─── Database (Turso) ────────────────────────────────────────
# Buat database gratis di https://turso.tech
# Install Turso CLI: winget install ChiselStrike.Turso
# Buat DB  : turso db create sibea
# Dapat URL : turso db show sibea --url
# Dapat token: turso db tokens create sibea

# Production & lokal (pakai Turso):
TURSO_DATABASE_URL="libsql://sibea-username.turso.io"
TURSO_AUTH_TOKEN="eyJhbGci..."

# Dev lokal TANPA Turso (SQLite file biasa):
# TURSO_DATABASE_URL="file:./dev.db"
# TURSO_AUTH_TOKEN=""   ← kosongkan, tidak dibutuhkan untuk file lokal

# Placeholder — dibutuhkan prisma CLI untuk migrasi lokal
DATABASE_URL="file:./dev.db"

# ─── NextAuth ────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="ganti-dengan-string-acak-panjang-minimal-32-karakter"
NEXTAUTH_URL="http://localhost:3000"

# ─── Admin ───────────────────────────────────────────────────
ADMIN_DEFAULT_PASSWORD="admin123"

# ─── Crawler (opsional) ──────────────────────────────────────
CRAWLER_TIMEOUT_MS=30000
CRAWLER_RETRY_ATTEMPTS=3

# ─── Penemuan Sumber Baru via Web Search (opsional) ──────────
# Mengaktifkan pencarian Google tiap crawl untuk menemukan sumber
# beasiswa S3 RESMI baru yang belum terdaftar (agregator dibuang).
# Tanpa ini, fitur penemuan via web dilewati (crawler resmi tetap jalan).
#
# Cara setup (gratis ~100 query/hari):
# 1. Buat API key: https://developers.google.com/custom-search/v1/introduction
#    → klik "Get a Key"
# 2. Buat Programmable Search Engine: https://programmablesearchengine.google.com/
#    → "Add" → set "Search the entire web" → salin Search engine ID (cx)
GOOGLE_SEARCH_API_KEY=""
GOOGLE_SEARCH_CX=""
# Jumlah query pencarian per crawl (hemat kuota). Default 8.
# Total 13 query tersedia (umum + per prodi), dirotasi per jam agar
# lintas waktu semua prodi tercakup. 8/crawl → ~12 crawl/hari (kuota 100/hari).
GOOGLE_SEARCH_MAX_QUERIES="8"
