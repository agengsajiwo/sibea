# ─── Database (Turso) ────────────────────────────────────────
# Buat database gratis di https://turso.tech
# Install Turso CLI: winget install ChiselStrike.Turso
# Buat DB  : turso db create sibea
# Dapat URL : turso db show sibea --url
# Dapat token: turso db tokens create sibea

# Production & lokal (pakai Turso):
TURSO_DATABASE_URL="libsql://sibea-username.turso.io"
TURSO_AUTH_TOKEN="eyJhbGci..."

# Dev lokal TANPA Turso (SQLite file biasa):
# TURSO_DATABASE_URL="file:./dev.db"
# TURSO_AUTH_TOKEN=""   ← kosongkan, tidak dibutuhkan untuk file lokal

# Placeholder — dibutuhkan prisma CLI untuk migrasi lokal
DATABASE_URL="file:./dev.db"

# ─── NextAuth ────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="ganti-dengan-string-acak-panjang-minimal-32-karakter"
NEXTAUTH_URL="http://localhost:3000"

# ─── Admin ───────────────────────────────────────────────────
ADMIN_DEFAULT_PASSWORD="admin123"

# ─── Crawler (opsional) ──────────────────────────────────────
CRAWLER_TIMEOUT_MS=30000
CRAWLER_RETRY_ATTEMPTS=3

# ─── Penemuan Sumber Baru via Web Search (opsional) ──────────
# Mengaktifkan pencarian web tiap crawl untuk menemukan sumber beasiswa
# S3 RESMI baru yang belum terdaftar (agregator dibuang). Tanpa ini,
# fitur penemuan dilewati (crawler situs resmi tetap jalan).
#
# PILIH SALAH SATU penyedia (Serper diprioritaskan bila keduanya diisi):
#
# Opsi 1 — Serper.dev (DISARANKAN, paling mudah, 1 key, hasil Google):
#   Daftar gratis di https://serper.dev → salin API key dari dashboard
SERPER_API_KEY=""
#
# Opsi 2 — Google Custom Search (cadangan, perlu 2 kode + enable API):
GOOGLE_SEARCH_API_KEY=""
GOOGLE_SEARCH_CX=""
#
# Jumlah query pencarian per crawl (hemat kuota). Default 8.
# Total 13 query (umum + per prodi), dirotasi per jam agar semua tercakup.
GOOGLE_SEARCH_MAX_QUERIES="8"
