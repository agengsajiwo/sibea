# ─── Database ────────────────────────────────────────────────
# Production (Vercel + Neon): dapatkan dari https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Development lokal dengan PostgreSQL:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/sibea"

# ─── NextAuth ────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="ganti-dengan-string-acak-panjang-minimal-32-karakter"

# Production: ganti dengan domain Vercel Anda
NEXTAUTH_URL="http://localhost:3000"

# ─── Admin ───────────────────────────────────────────────────
ADMIN_DEFAULT_PASSWORD="admin123"

# ─── Crawler (opsional) ──────────────────────────────────────
CRAWLER_TIMEOUT_MS=30000
CRAWLER_RETRY_ATTEMPTS=3
