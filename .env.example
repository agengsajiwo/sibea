# ─── Database (Turso) ────────────────────────────────────────
# Buat database gratis di https://turso.tech
# Install Turso CLI: winget install ChiselStrike.Turso
# Buat DB  : turso db create sibea
# Dapat URL : turso db show sibea --url
# Dapat token: turso db tokens create sibea

# Production & lokal (pakai Turso):
TURSO_DATABASE_URL="libsql://sibea-username.turso.io"
TURSO_AUTH_TOKEN="eyJhbGci..."

# Dev lokal TANPA Turso (SQLite file biasa):
# TURSO_DATABASE_URL="file:./dev.db"
# TURSO_AUTH_TOKEN=""   ← kosongkan, tidak dibutuhkan untuk file lokal

# Placeholder — dibutuhkan prisma CLI untuk migrasi lokal
DATABASE_URL="file:./dev.db"

# ─── NextAuth ────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="ganti-dengan-string-acak-panjang-minimal-32-karakter"
NEXTAUTH_URL="http://localhost:3000"

# ─── Admin ───────────────────────────────────────────────────
ADMIN_DEFAULT_PASSWORD="admin123"

# ─── Crawler (opsional) ──────────────────────────────────────
CRAWLER_TIMEOUT_MS=30000
CRAWLER_RETRY_ATTEMPTS=3
