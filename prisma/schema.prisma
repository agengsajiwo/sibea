generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  // Provider sqlite — Turso adalah SQLite-compatible
  // Koneksi aktual ditangani adapter libSQL di lib/prisma.ts
  // DATABASE_URL digunakan prisma CLI untuk migrasi lokal
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Scholarship {
  id                 String    @id @default(cuid())
  namaBeasiswa       String
  penyelenggara      String
  lokasi             String
  pilihanLokasi      String
  skemaPembiayaan    String
  jenisPembiayaan    String
  komponenPembiayaan String
  keterangan         String
  linkPendaftaran    String
  sumberCrawling     String
  deadline           DateTime?
  status             String    @default("DRAFT")
  contentHash        String
  tanggalCrawling    DateTime  @default(now())
  reviewedBy         String?
  reviewedAt         DateTime?
  isActive           Boolean   @default(true)
  isManualEntry      Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status])
  @@index([lokasi])
  @@index([deadline])
  @@index([contentHash])
}

model CrawlLog {
  id               String   @id @default(cuid())
  sumber           String
  status           String
  jumlahDitemukan  Int      @default(0)
  jumlahBaru       Int      @default(0)
  jumlahDiperbarui Int      @default(0)
  errorMessage     String?
  durasiMs         Int      @default(0)
  createdAt        DateTime @default(now())
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Pemantau perubahan halaman sumber (crawl-as-monitor).
// Untuk sumber server-rendered yang stabil (Kemdikbud, LPDP, Kemenag, BRIN):
// crawler mengambil halaman, hash konten teksnya, dan mendeteksi perubahan
// dibanding crawl sebelumnya. Jika berubah → tandai untuk ditinjau admin.
model SourceMonitor {
  id                  String    @id @default(cuid())
  sumber              String    @unique // nama crawler, mis. "Kemdikbud BPI"
  sourceUrl           String
  pageHash            String    @default("") // hash teks halaman terakhir
  lastChecked         DateTime  @default(now())
  lastChanged         DateTime?
  hasUnreviewedChange Boolean   @default(false)
  lastError           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}
